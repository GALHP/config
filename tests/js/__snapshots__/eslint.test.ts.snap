    "parser": "typescript-eslint/parser@8.58.2",
    "parserOptions": {
      "ecmaFeatures": {
        "jsx": true,
      },
      "ecmaVersion": "latest",
      "extraFileExtensions": {},
      "projectService": {},
      "sourceType": "module",
      "tsconfigRootDir": ".",
    },
    "sourceType": "module",
  },
  "linterOptions": {
    "reportUnusedDisableDirectives": 2,
  },
  "plugins": [
    "@",
    "antfu:antfu@3.2.2",
    "unused:unused-imports",
    "ts:@typescript-eslint/eslint-plugin@8.58.2",
    "test:vitest@1.6.15",
    "jsdoc",
    "examples:eslint-plugin-jsdoc/processor@62.9.0",
    "node:eslint-plugin-n@17.24.0",
    "brnshkr:brnshkr@<version>",
    "comments",
    "regexp:eslint-plugin-regexp@3.1.0",
    "unicorn:eslint-plugin-unicorn@64.0.0",
    "import:eslint-plugin-import-x@4.16.2",
    "style:@stylistic/eslint-plugin@5.10.0",
    "perfectionist:eslint-plugin-perfectionist@5.8.0",
    "svelte:eslint-plugin-svelte@3.17.0",
    "json:@eslint/json@1.2.0",
    "jsonc:eslint-plugin-jsonc@3.1.2",
    "toml:eslint-plugin-toml@1.3.1",
    "yaml:eslint-plugin-yml@3.3.1",
    "css:@eslint/css@1.1.0",
    "markdown:@eslint/markdown@8.0.1",
  ],
  "processor": "eslint-plugin-jsdoc/preprocessor@62.9.0",
  "rules": {
    "accessor-pairs": [
      2,
      {
        "enforceForClassMembers": true,
        "enforceForTSTypes": false,
        "getWithoutSet": false,
        "setWithoutGet": true,
      },
    ],
    "antfu/consistent-chaining": [
      2,
    ],
    "antfu/import-dedupe": [
      2,
    ],
    "antfu/no-import-dist": [
      2,
    ],
    "antfu/no-import-node-modules-by-path": [
      2,
    ],
    "antfu/no-ts-export-equal": [
      2,
    ],
    "array-callback-return": [
      2,
      {
        "allowImplicit": false,
        "allowVoid": false,
        "checkForEach": true,
      },
    ],
    "arrow-body-style": [
      2,
      "as-needed",
    ],
    "block-scoped-var": [
      2,
    ],
    "brnshkr/require-import-attributes": [
      2,
    ],
    "capitalized-comments": [
      2,
      "always",
      {
        "block": {
          "ignoreInlineComments": true,
        },
        "line": {
          "ignorePattern": ".*",
        },
      },
    ],
    "class-methods-use-this": [
      2,
      {
        "enforceForClassFields": true,
        "exceptMethods": [],
        "ignoreOverrideMethods": true,
      },
    ],
    "comments/disable-enable-pair": [
      2,
    ],
    "comments/no-aggregating-enable": [
      2,
    ],
    "comments/no-duplicate-disable": [
      2,
    ],
    "comments/no-unlimited-disable": [
      2,
    ],
    "comments/no-unused-enable": [
      2,
    ],
    "comments/require-description": [
      2,
    ],
    "complexity": [
      2,
      {
        "max": 10,
        "variant": "modified",
      },
    ],
    "consistent-return": [
      0,
      {
        "treatUndefinedAsUnspecified": false,
      },
    ],
    "consistent-this": [
      2,
      "that",
    ],
    "constructor-super": [
      2,
    ],
    "curly": [
      2,
      "all",
    ],
    "default-case": [
      2,
      {},
    ],
    "default-case-last": [
      2,
    ],
    "default-param-last": [
      2,
    ],
    "dot-notation": [
      0,
      {
        "allowKeywords": true,
        "allowPattern": "",
      },
    ],
    "eqeqeq": [
      2,
    ],
    "for-direction": [
      2,
    ],
    "func-name-matching": [
      2,
      {
        "considerPropertyDescriptor": true,
        "includeCommonJSModuleExports": true,
      },
    ],
    "func-names": [
      2,
      "always",
      {},
    ],
    "func-style": [
      2,
      "expression",
      {
        "allowArrowFunctions": false,
        "allowTypeAnnotation": false,
        "overrides": {},
      },
    ],
    "getter-return": [
      2,
      {
        "allowImplicit": false,
      },
    ],
    "grouped-accessor-pairs": [
      2,
      "anyOrder",
      {
        "enforceForTSTypes": false,
      },
    ],
    "guard-for-in": [
      2,
    ],
    "import/consistent-type-specifier-style": [
      2,
      "prefer-top-level",
    ],
    "import/default": [
      2,
    ],
    "import/export": [
      2,
    ],
    "import/extensions": [
      2,
      "ignorePackages",
      {
        "cts": "never",
        "js": "never",
        "mts": "never",
        "ts": "never",
      },
    ],
    "import/first": [
      2,
    ],
    "import/max-dependencies": [
      0,
      {
        "max": 15,
      },
    ],
    "import/named": [
      0,
    ],
    "import/namespace": [
      2,
    ],
    "import/newline-after-import": [
      2,
    ],
    "import/no-absolute-path": [
      2,
    ],
    "import/no-amd": [
      2,
    ],
    "import/no-cycle": [
      2,
      {
        "allowUnsafeDynamicCyclicDependency": false,
        "ignoreExternal": false,
        "maxDepth": 3,
      },
    ],
    "import/no-default-export": [
      0,
    ],
    "import/no-deprecated": [
      2,
    ],
    "import/no-duplicates": [
      2,
    ],
    "import/no-dynamic-require": [
      2,
    ],
    "import/no-empty-named-blocks": [
      2,
    ],
    "import/no-extraneous-dependencies": [
      2,
      {
        "devDependencies": [
          "**/*.config.?(c|m)[jt]s",
          "**/{conf,tests}/**",
          "**/types/declarations/reset.d.ts",
        ],
      },
    ],
    "import/no-import-module-exports": [
      2,
    ],
    "import/no-mutable-exports": [
      2,
    ],
    "import/no-named-as-default": [
      2,
    ],
    "import/no-named-as-default-member": [
      0,
    ],
    "import/no-named-default": [
      2,
    ],
    "import/no-namespace": [
      2,
    ],
    "import/no-relative-packages": [
      2,
    ],
    "import/no-rename-default": [
      0,
    ],
    "import/no-self-import": [
      2,
    ],
    "import/no-unassigned-import": [
      2,
      {
        "allow": [
          "**/*.{css,scss}",
        ],
      },
    ],
    "import/no-unresolved": [
      2,
      {
        "caseSensitive": true,
        "commonjs": true,
      },
    ],
    "import/no-useless-path-segments": [
      2,
      {
        "noUselessIndex": true,
      },
    ],
    "import/no-webpack-loader-syntax": [
      2,
    ],
    "import/order": [
      2,
      {
        "alphabetize": {
          "caseInsensitive": true,
          "order": "asc",
          "orderImportKind": "ignore",
        },
        "consolidateIslands": "inside-groups",
        "distinctGroup": true,
        "groups": [
          "builtin",
          "external",
          "unknown",
          "internal",
          "parent",
          "sibling",
          "index",
          "object",
          "type",
        ],
        "named": {
          "enabled": true,
          "types": "types-last",
        },
        "newlines-between": "always-and-inside-groups",
        "newlines-between-types": "never",
        "pathGroups": [
          {
            "group": "object",
            "pattern": "**/*.{css,scss}",
          },
        ],
        "sortTypesGroup": true,
        "warnOnUnassignedImports": true,
      },
    ],
    "import/unambiguous": [
      0,
    ],
    "init-declarations": [
      2,
    ],
    "jsdoc/check-access": [
      2,
    ],
    "jsdoc/check-alignment": [
      2,
    ],
    "jsdoc/check-examples": [
      0,
    ],
    "jsdoc/check-indentation": [
      2,
      {
        "allowIndentedSections": true,
      },
    ],
    "jsdoc/check-line-alignment": [
      2,
    ],
    "jsdoc/check-param-names": [
      2,
    ],
    "jsdoc/check-property-names": [
      2,
    ],
    "jsdoc/check-syntax": [
      2,
    ],
    "jsdoc/check-tag-names": [
      2,
    ],
    "jsdoc/check-template-names": [
      2,
    ],
    "jsdoc/check-types": [
      2,
    ],
    "jsdoc/check-values": [
      2,
    ],
    "jsdoc/convert-to-jsdoc-comments": [
      2,
      {
        "lineOrBlockStyle": "block",
      },
    ],
    "jsdoc/empty-tags": [
      2,
    ],
    "jsdoc/escape-inline-tags": [
      2,
    ],
    "jsdoc/implements-on-classes": [
      2,
    ],
    "jsdoc/imports-as-dependencies": [
      2,
    ],
    "jsdoc/informative-docs": [
